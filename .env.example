# ============================================================
# Kitchen Sync Manager — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# --- JWT Secret (REQUIRED in production) ---
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=super-secret-key-CHANGE-ME-in-production

# --- Database Configuration ---
# Option A: MySQL connection URL
# MYSQL_URL=mysql://user:pass@host:port/kitchen_sync

# Option B: MySQL individual variables
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=kitchen_sync

# If neither MYSQL_URL nor MYSQL_HOST is set, SQLite will be used (stored in ./data/kitchen.db)

# --- Application ---
NODE_ENV=development
PORT=3000

# --- Admin Seeding ---
# Set to 'true' to seed a default admin user (admin/admin) on startup.
# In development mode, admin is always seeded.
# In production, this must be explicitly set.
# IMPORTANT: Change the admin password immediately after first login!
SEED_ADMIN=false

# --- Gemini API (for AI features) ---
# GEMINI_API_KEY=your-gemini-api-key
