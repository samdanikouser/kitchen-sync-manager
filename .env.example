# ============================================================
# Kitchen Sync Manager — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# --- JWT Secret (REQUIRED in production) ---
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=super-secret-key-CHANGE-ME-in-production

# --- Database Configuration ---
# Priority: PostgreSQL > MySQL > SQLite (fallback)
# Only ONE database section needs to be configured.

# Option 1: PostgreSQL (recommended for Render / production)
# DATABASE_URL=postgresql://user:pass@host:5432/kitchen_sync
# Or use individual variables:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=
# PG_DATABASE=kitchen_sync

# Option 2: MySQL
# MYSQL_URL=mysql://user:pass@host:3306/kitchen_sync
# Or use individual variables:
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=kitchen_sync

# Option 3: SQLite (default — no config needed)
# Stored in ./data/kitchen.db automatically

# --- Application ---
NODE_ENV=development
PORT=3000

# --- Admin Seeding ---
# Set to 'true' to seed a default admin user (admin/admin) on startup.
# In development mode, admin is always seeded.
# In production, this must be explicitly set.
# IMPORTANT: Change the admin password immediately after first login!
SEED_ADMIN=false

# --- Stripe Payment Gateway ---
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_... or sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# If not set, subscription activates directly without payment (test mode).

# --- Gemini API (for AI features) ---
# GEMINI_API_KEY=your-gemini-api-key
